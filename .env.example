# Copy to .env.local (for `vercel dev`) or set in your Vercel project settings.

# Google AI Studio API key — required for the try-on feature.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the image model. Defaults to gemini-2.5-flash-image.
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
