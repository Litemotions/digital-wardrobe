# Copy to .env.local (for `vercel dev`) or set in your Vercel project settings.
# The try-on engine auto-selects OpenAI if OPENAI_API_KEY is set, else Gemini.

# --- OpenAI (recommended if you already have a key) -------------------
# Uses the gpt-image-1 model. Requires billing enabled on your OpenAI account.
OPENAI_API_KEY=
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_QUALITY=high      # low | medium | high
# OPENAI_IMAGE_SIZE=1024x1536    # portrait works best for full-body try-on

# --- Google Gemini (alternative) -------------------------------------
# Uses gemini-2.5-flash-image. Image generation needs a billing-enabled
# Google project (the free tier's quota for it is 0).
# GEMINI_API_KEY=
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# --- Force a provider (optional) -------------------------------------
# TRYON_PROVIDER=openai          # openai | gemini
