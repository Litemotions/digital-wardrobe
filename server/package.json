{
  "name": "digital-wardrobe-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Auth + storage API for Digital Wardrobe, backed by MariaDB. Runs at home next to the database; exposed to the app over HTTPS via a Cloudflare Tunnel.",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.5",
    "nodemailer": "^6.9.16",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^6.4.17",
    "typescript": "^5.6.3"
  }
}
