# Copy to .env and fill in. Never commit the real .env.

# --- MariaDB connection (your Home Assistant database) ----------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=wardrobe
DB_USER=wardrobe
DB_PASSWORD=change-me

# --- Auth -------------------------------------------------------------
# A long random string. Generate one, e.g.:  openssl rand -hex 32
JWT_SECRET=

# --- HTTP -------------------------------------------------------------
PORT=8080
# Comma-separated list of allowed browser origins (your app URL).
# Example: https://digital-wardrobe-sable.vercel.app
# Use * only for local testing.
ALLOWED_ORIGINS=*
