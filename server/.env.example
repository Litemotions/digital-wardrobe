# Copy to .env and fill in. Never commit the real .env.
# (When running as a Home Assistant add-on, set these in the add-on
# Configuration tab instead — they map to these same names.)

# --- MariaDB connection (your Home Assistant database) ----------------
DB_HOST=core-mariadb
DB_PORT=3306
DB_NAME=wardrobe
DB_USER=wardrobe
DB_PASSWORD=change-me

# --- Auth -------------------------------------------------------------
# A long random string. Generate one, e.g.:  openssl rand -hex 32
JWT_SECRET=
# Seeded as the first admin on the invite allowlist.
ADMIN_EMAIL=jibril@litemotions.dk
# Public URL of the web app — used to build the magic-link sign-in URL.
APP_URL=https://digital-wardrobe-sable.vercel.app

# --- Magic-link email (optional) --------------------------------------
# If blank, sign-in links are printed to the server log instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- HTTP -------------------------------------------------------------
PORT=8080
# Comma-separated allowed browser origins (your app URL).
ALLOWED_ORIGINS=https://digital-wardrobe-sable.vercel.app
